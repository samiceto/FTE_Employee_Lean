# WhatsApp & browser sessions (local only)
whatsapp_session/
*_user_data/

# Logs (large, generated)
logs/*.log

# Vault — keep folder STRUCTURE only, never commit real scraped data (emails, messages, etc.)
ai_employee_vault/**
!ai_employee_vault/**/
!ai_employee_vault/**/.gitkeep
ai_employee_vault/.obsidian/

# Test artifacts
.pytest_cache/
